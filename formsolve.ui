  <property name="styleSheet">
   <string notr="true">
    QWidget {
        background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                    stop:0 #f0f4f8,
                                    stop:1 #e2e8f0);
        font-family: 'Segoe UI', sans-serif;
        color: #0f172a;
    }

    QLabel#titleLabel {
        color: #0f172a;
        font-size: 24px;
        font-weight: 700;
        padding: 15px;
        background: rgba(255,255,255,0.7);
        border-radius: 15px;
    }

    QGroupBox {
        font-weight: 600;
        font-size: 14px;
        color: #0f172a;
        border: none;
        background: rgba(255,255,255,0.85);
        border-radius: 20px;
        margin-top: 15px;
        padding-top: 15px;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        left: 20px;
        top: 0px;
        padding: 0 12px;
        background: #ffffff;
        border-radius: 20px;
        color: #1e40af;
        font-size: 15px;
    }

    QLabel {
        color: #0f172a;
    }

    QPushButton {
        background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                    stop:0 #3b82f6,
                                    stop:1 #2563eb);
        color: white;
        border: none;
        border-radius: 40px;
        padding: 10px 24px;
        font-size: 14px;
        font-weight: 600;
    }
    QPushButton:hover {
        background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                    stop:0 #2563eb,
                                    stop:1 #1d4ed8);
    }
    QPushButton#backButton {
        background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                    stop:0 #94a3b8,
                                    stop:1 #64748b);
    }
   </string>
  </property>
  <layout class="QVBoxLayout" name="mainLayout">
   <property name="spacing">
    <number>20</number>
   </property>
   <property name="leftMargin">
    <number>20</number>
   </property>
   <property name="topMargin">
    <number>20</number>
   </property>
   <property name="rightMargin">
    <number>20</number>
   </property>
   <property name="bottomMargin">
    <number>20</number>
   </property>
   <item>
    <widget class="QLabel" name="titleLabel">
     <property name="text">
      <string>🧠 Исследование функции | Вариант 29</string>
     </property>
     <property name="alignment">
      <set>Qt::AlignCenter</set>
     </property>
    </widget>
   </item>
   <item>
    <layout class="QHBoxLayout" name="contentLayout">
     <property name="spacing">
      <number>20</number>
     </property>
     <item>
      <widget class="QGroupBox" name="taskGroup">
       <property name="title">
        <string>📌 Условие задачи</string>
       </property>
       <property name="minimumSize">
        <size>
         <width>450</width>
         <height>0</height>
        </size>
       </property>
       <layout class="QVBoxLayout" name="taskLayout">
        <item>
         <widget class="QLabel" name="systemLabel">
          <property name="text">
           <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;
&lt;div align=&quot;center&quot;&gt;
&lt;table style=&quot;font-family: 'Times New Roman', 'Consolas', serif; font-size: 18px; border-collapse: collapse; color: #0f172a;&quot;&gt;
&lt;tr&gt;
    &lt;td style=&quot;font-size: 42px; vertical-align: middle; color: #1e40af;&quot;&gt;{&lt;/td&gt;
    &lt;td style=&quot;padding: 8px; text-align: left; color: #0f172a;&quot;&gt;
        a·√x, &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;0 ≤ x &amp;lt; 1&lt;br&gt;
        b/x, &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;1 ≤ x &amp;lt; 2&lt;br&gt;
        c·x² - d·x + e, &amp;nbsp;x ≥ 2
    &lt;/td&gt;
&lt;/tr&gt;
&lt;/table&gt;
&lt;/div&gt;
&lt;/body&gt;&lt;/html&gt;</string>
          </property>
          <property name="alignment">
           <set>Qt::AlignCenter</set>
          </property>
          <property name="styleSheet">
           <string>background: #ffffff; border-radius: 20px; padding: 25px; border: 2px solid #3b82f6; color: #0f172a;</string>
          </property>
         </widget>
        </item>
       </layout>
      </widget>
     </item>
     <item>
      <widget class="QGroupBox" name="researchGroup">
       <property name="title">
        <string>🔬 Аналитические свойства</string>
       </property>
       <property name="minimumSize">
        <size>
         <width>480</width>
         <height>0</height>
        </size>
       </property>
       <layout class="QVBoxLayout" name="researchLayout">
        <property name="spacing">
         <number>10</number>
        </property>
        <item>
         <widget class="QLabel" name="domainLabel">
          <property name="text">
           <string>📌 Область определения: [0; +∞)</string>
          </property>
          <property name="styleSheet">
           <string>background: rgba(255,255,255,0.7); border-radius: 12px; padding: 8px 12px; font-weight: 500; color: #0f172a;</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="continuityLabel">
          <property name="text">
           <string>🔗 Непрерывность: зависит от параметров a, b, c, d, e</string>
          </property>
          <property name="styleSheet">
           <string>background: rgba(255,255,255,0.7); border-radius: 12px; padding: 8px 12px; font-weight: 500; color: #0f172a;</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="derivativeLabel">
          <property name="text">
           <string>📈 Производная:
   • 0 &lt; x &lt; 1:  f'(x) = a / (2√x)
   • 1 &lt; x &lt; 2:  f'(x) = -b / x²
   • x &gt; 2:     f'(x) = 2c·x - d</string>
          </property>
          <property name="styleSheet">
           <string>background: rgba(255,255,255,0.7); border-radius: 12px; padding: 8px 12px; font-weight: 500; font-family: 'Consolas', monospace; color: #0f172a;</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="monotonicityLabel">
          <property name="text">
           <string>📉 Монотонность:
   • (0;1): зависит от знака a
   • (1;2): зависит от знака b
   • (2;+∞): зависит от c и d</string>
          </property>
          <property name="styleSheet">
           <string>background: rgba(255,255,255,0.7); border-radius: 12px; padding: 8px 12px; font-weight: 500; color: #0f172a;</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="extremumLabel">
          <property name="text">
           <string>⚠️ Экстремумы:
   • x = 1, x = 2 — точки излома
   • x = d/(2c) — возможный экстремум (при x &gt; 2, c ≠ 0)</string>
          </property>
          <property name="styleSheet">
           <string>background: rgba(255,255,255,0.7); border-radius: 12px; padding: 8px 12px; font-weight: 500; color: #0f172a;</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="asymptotesLabel">
          <property name="text">
           <string>📏 Асимптоты:
   • Вертикальные: отсутствуют
   • Горизонтальные: y = 0 при x → +∞ (для ветки 1/x)</string>
          </property>
          <property name="styleSheet">
           <string>background: rgba(255,255,255,0.7); border-radius: 12px; padding: 8px 12px; font-weight: 500; color: #0f172a;</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="parityLabel">
          <property name="text">
           <string>🔄 Чётность: функция ни чётная, ни нечётная</string>
          </property>
          <property name="styleSheet">
           <string>background: rgba(255,255,255,0.7); border-radius: 12px; padding: 8px 12px; font-weight: 500; color: #0f172a;</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="boundaryLabel">
          <property name="text">
           <string>🎯 Значения в граничных точках:
   • f(0) = 0
   • f(1) = b
   • f(2) = 4c - 2d + e</string>
          </property>
          <property name="styleSheet">
           <string>background: rgba(255,255,255,0.7); border-radius: 12px; padding: 8px 12px; font-weight: 500; color: #0f172a;</string>
          </property>
         </widget>
        </item>
       </layout>
      </widget>
     </item>
    </layout>
   </item>
   <item>
    <layout class="QHBoxLayout" name="buttonLayout">
