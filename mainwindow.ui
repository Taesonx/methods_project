                                    stop:0 #10b981,
                                    stop:1 #059669);
        min-width: 120px;
        padding: 8px 15px;
    }
    QPushButton#calculateSingleButton:hover {
        background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                    stop:0 #059669,
                                    stop:1 #047857);
    }

    QTableWidget {
        background-color: #ffffff;
        alternate-background-color: #f8fafc;
        color: #0f172a;
        gridline-color: #e2e8f0;
        border: 1px solid #cbd5e1;
        border-radius: 12px;
        font-size: 11px;
    }
    QTableWidget::item {
