  <property name="styleSheet">
   <string notr="true">
    QMainWindow {
        background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                    stop:0 #f0f4f8,
                                    stop:1 #e2e8f0);
        font-family: 'Segoe UI', sans-serif;
    }

    QLabel#titleLabel {
        color: #1e293b;
        font-size: 20px;
        font-weight: 700;
        padding: 10px;
        background: rgba(255,255,255,0.7);
        border-radius: 12px;
    }

    QLabel#formulaLabel {
        background: rgba(255,255,255,0.9);
        border: 1px solid #cbd5e1;
        border-radius: 12px;
        padding: 10px;
        font-family: 'Consolas', monospace;
        font-size: 14px;
        color: #1e40af;
    }

    QGroupBox {
        font-weight: 600;
        font-size: 13px;
        color: #0f172a;
        border: none;
        background: rgba(255,255,255,0.85);
        border-radius: 16px;
        margin-top: 12px;
        padding-top: 12px;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        left: 15px;
        top: 0px;
        padding: 0 10px;
        background: #ffffff;
        border-radius: 16px;
        color: #2563eb;
        font-size: 14px;
    }

    QLabel {
        color: #0f172a;
        font-weight: 500;
    }

    QDoubleSpinBox, QSpinBox {
        background-color: #ffffff;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        padding: 5px 8px;
        font-size: 12px;
        color: #0f172a;
        min-width: 80px;
    }
    QDoubleSpinBox:focus, QSpinBox:focus {
        border: 2px solid #3b82f6;
    }

    QLineEdit {
        background-color: #ffffff;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        padding: 8px 10px;
        font-size: 13px;
        color: #0f172a;
        min-width: 120px;
    }
    QLineEdit:focus {
        border: 2px solid #3b82f6;
    }

    QSlider::groove:horizontal {
        height: 6px;
        background: #e2e8f0;
        border-radius: 3px;
    }
    QSlider::handle:horizontal {
        background: #3b82f6;
        width: 16px;
        height: 16px;
        margin: -5px 0;
        border-radius: 8px;
    }
    QSlider::handle:horizontal:hover {
        background: #2563eb;
    }

    QPushButton {
        background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                    stop:0 #3b82f6,
                                    stop:1 #2563eb);
        color: white;
        border: none;
        border-radius: 30px;
        padding: 8px 20px;
        font-size: 13px;
        font-weight: 600;
        min-width: 100px;
    }
    QPushButton:hover {
        background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                    stop:0 #2563eb,
                                    stop:1 #1d4ed8);
    }
    QPushButton:pressed {
        background: #1e40af;
    }
    QPushButton#backToSolveButton {
        background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                    stop:0 #6c757d,
                                    stop:1 #5a6268);
        min-width: 140px;
    }
    QPushButton#backToSolveButton:hover {
        background: #5a6268;
    }
    QPushButton#backButton {
        background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                    stop:0 #dc3545,
                                    stop:1 #c82333);
        min-width: 140px;
    }
    QPushButton#backButton:hover {
        background: #c82333;
    }
    QPushButton#calculateSingleButton {
        background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                    stop:0 #10b981,
                                    stop:1 #059669);
        min-width: 120px;
        padding: 8px 15px;
    }
    QPushButton#calculateSingleButton:hover {
        background: #059669;
    }

    QTableWidget {
        background-color: #ffffff;
        alternate-background-color: #f8fafc;
        color: #0f172a;
        gridline-color: #e2e8f0;
        border: 1px solid #cbd5e1;
        border-radius: 12px;
        font-size: 11px;
    }
    QTableWidget::item {
        padding: 6px;
    }
    QHeaderView::section {
        background-color: #f1f5f9;
        color: #1e293b;
        padding: 8px;
        border: none;
        font-weight: 600;
    }

    QChartView {
